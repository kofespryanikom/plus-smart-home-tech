@namespace("ru.yandex.practicum.kafka.telemetry.hub.scenario")
protocol ScenarioConditionProtocol {
	import idl "ConditionTypeAvro.avdl";
	import idl "ConditionOperationAvro.avdl";

	record ScenarioConditionAvro {
		string sensor_id;
		ConditionTypeAvro type;
		ConditionOperationAvro operation;
		union{null, int, boolean} value = null;
	}
}
